# 🌐 CLICKBAZAAR CLIENT - ENVIRONMENT VARIABLES (LOCAL DEVELOPMENT)
# Frontend configuration for local development only
# =====================================================
# Copy this file to .env and add your actual values
# Documentation: https://github.com/DebasmitaBose0/ClickBazaar

# 🔌 API ENDPOINT
# Local Development: http://localhost:4100
API_URL=http://localhost:4100

# 🏢 APPLICATION CONFIGURATION
APP_NAME=ClickBazaar

# Environment mode: development (local only)
ENVIRONMENT=development
