# SERVER & RUNTIME CONFIGURATION (LOCAL DEVELOPMENT ONLY)
PORT=4100
NODE_ENV=development

# AUTHENTICATION & SECURITY
JWT_SECRET=your-32-char-random-secret-key
ADMIN_EMAIL=admin@localhost
ADMIN_KEY=your-admin-verification-key

# AI & EXTERNAL SERVICES (OPTIONAL)
GOOGLE_API_KEY=your-google-api-key-optional
GROQ_API_KEY=your-groq-api-key-optional

# EMAIL CONFIGURATION (GMAIL SMTP - LOCAL TESTING ONLY)
# SMTP handles all emails: OTP, Password Recovery, Support Inquiries
# Get Gmail App Password: https://myaccount.google.com/apppasswords
EMAIL_USER=your-test-email@gmail.com
EMAIL_PASSWORD=your-16-char-app-password
REPLY_EMAIL=your-test-email@gmail.com
